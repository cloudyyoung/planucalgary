datasource db {
  provider = "postgresql"
  schemas  = ["planucalgary", "catalog"]
}

generator client {
  provider        = "prisma-client"
  output          = "../src/contracts/generated/prisma/"
  previewFeatures = ["fullTextSearchPostgres"]
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "../src/contracts/generated/zod/"
}
